import streamlit as st
import json
import os
from datetime import date

# 1. Password Protection
def check_password():
    if "password_correct" not in st.session_state:
        st.session_state.password_correct = False

    if not st.session_state.password_correct:
        st.title("💌 Letters to Bub")
        pwd = st.text_input("Enter Password", type="password")
        if st.button("Unlock"):
            if pwd == "YOUR_CHOSEN_PASSWORD": # Change this!
                st.session_state.password_correct = True
                st.rerun()
            else:
                st.error("Incorrect password")
        return False
    return True

if check_password():
    st.title("💌 Letters to Bub")

    # 2. Data Storage Logic
    DB_FILE = "journal_data.json"
    if not os.path.exists(DB_FILE):
        with open(DB_FILE, "w") as f:
            json.dump([], f)

    def load_entries():
        with open(DB_FILE, "r") as f:
            return json.load(f)

    def save_entry(title, content):
        entries = load_entries()
        entries.insert(0, {"title": title, "content": content}) # Newest first
        with open(DB_FILE, "w") as f:
            json.dump(entries, f)

    # 3. Input Section
    with st.expander("➕ Create New Letter"):
        entry_date = st.date_input("Date", date.today())
        entry_title = st.text_input("Title/Topic", placeholder="e.g., Project Update")
        entry_text = st.text_area("Your message")
        
        if st.button("Post Entry"):
            if entry_text:
                full_title = f"{entry_date} - {entry_title}"
                save_entry(full_title, entry_text)
                st.success("Saved!")
                st.rerun()

    st.divider()

    # 4. Display Section (Open/Close functionality)
    st.subheader("Past Entries")
    entries = load_entries()
    for item in entries:
        with st.expander(item['title']):
            st.write(item['content'])
